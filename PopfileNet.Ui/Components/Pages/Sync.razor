@page "/sync"
@using PopfileNet.Ui.Services

<FluentCard>
    <h2>Mail Sync</h2>
    
    <FluentStack Orientation="Orientation.Vertical" Gap="20">
        <FluentStack Orientation="Orientation.Horizontal" Gap="10">
            <FluentButton Appearance="Appearance.Accent" @onclick="RefreshFolders">Refresh Folders</FluentButton>
            <FluentButton @onclick="SyncAll">Sync All Emails</FluentButton>
        </FluentStack>
        
        <table>
            <thead>
                <tr>
                    <th>Folder Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var folder in Folders)
                {
                    <tr>
                        <td>@folder.Name</td>
                        <td><FluentButton @onclick="() => SyncFolder(folder.Name)">Sync</FluentButton></td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if (IsLoading)
        {
            <FluentProgressRing />
        }
        
        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <FluentBadge Appearance="Appearance.Neutral">
                @StatusMessage
            </FluentBadge>
        }
    </FluentStack>
</FluentCard>

<FluentCard>
    <h2>Database Statistics</h2>
    
    <p>Total Folders: @(FoldersResponse?.TotalCount ?? 0)</p>
    <p>Total Emails: @(MailsResponse?.TotalCount ?? 0)</p>
</FluentCard>

<FluentCard>
    <h2>Recent Emails</h2>
    
    @if (MailsResponse?.Items.Count > 0)
    {
        <table>
            <thead>
                <tr>
                    <th>Subject</th>
                    <th>From</th>
                    <th>Date</th>
                    <th>Bucket</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var email in MailsResponse.Items)
                {
                    <tr>
                        <td>@email.Subject</td>
                        <td>@email.FromAddress</td>
                        <td>@email.ReceivedDate.ToString("g")</td>
                        <td>@email.BucketName</td>
                    </tr>
                }
            </tbody>
        </table>
        
        <FluentStack Orientation="Orientation.Horizontal" Gap="10" Style="margin-top: 10px;">
            <FluentButton @onclick="PreviousPage" Disabled="@(MailsResponse.Page <= 1)">Previous</FluentButton>
            <span>Page @MailsResponse.Page of @MailsResponse.TotalPages</span>
            <FluentButton @onclick="NextPage" Disabled="@(!MailsResponse.HasNext)">Next</FluentButton>
        </FluentStack>
    }
    else
    {
        <p>No emails in database.</p>
    }
</FluentCard>

@code {
    [Inject]
    public IApiClient Api { get; set; } = null!;
    
    public List<FolderDto> Folders { get; set; } = [];
    public PagedResponse<FolderDto>? FoldersResponse { get; set; }
    public PagedResponse<EmailDto>? MailsResponse { get; set; }
    public bool IsLoading { get; set; }
    public string StatusMessage { get; set; } = "";
    public int CurrentPage { get; set; } = 1;
    
    protected override async Task OnInitializedAsync()
    {
        await RefreshFolders();
        await LoadMails();
    }
    
    private async Task RefreshFolders()
    {
        IsLoading = true;
        try
        {
            FoldersResponse = await Api.GetFoldersAsync(1, 100);
            Folders = FoldersResponse?.Items ?? [];
            StatusMessage = "";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
    
    private async Task LoadMails()
    {
        try
        {
            MailsResponse = await Api.GetMailsAsync(CurrentPage, 20);
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error loading emails: {ex.Message}";
        }
    }
    
    private async Task SyncFolder(string folderName)
    {
        IsLoading = true;
        try
        {
            var result = await Api.SyncEmailsAsync();
            StatusMessage = result?.Message ?? "Sync completed";
            await LoadMails();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
    
    private async Task SyncAll()
    {
        IsLoading = true;
        try
        {
            var result = await Api.SyncEmailsAsync();
            StatusMessage = result?.Message ?? "Sync completed";
            await LoadMails();
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
    
    private async Task PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
            await LoadMails();
        }
    }
    
    private async Task NextPage()
    {
        if (MailsResponse?.HasNext == true)
        {
            CurrentPage++;
            await LoadMails();
        }
    }
}
