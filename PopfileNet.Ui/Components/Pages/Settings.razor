@page "/settings"
@using PopfileNet.Ui.Services

<FluentCard data-testid="settings-imap-card">
    <h2>IMAP Settings</h2>
    
    <FluentStack Orientation="Orientation.Vertical" Gap="20" data-testid="settings-imap-stack">
        <FluentTextField @bind-Value="Server" Label="IMAP Server" Placeholder="imap.example.com" />
        <FluentNumberField @bind-Value="Port" Label="Port" Min="1" Max="65535" />
        <FluentTextField @bind-Value="Username" Label="Username" Placeholder="user@example.com" />
        <FluentTextField @bind-Value="Password" Label="Password" Type="Password" />
        <FluentSwitch @bind-Checked="UseSsl" Label="Use SSL" />
        <FluentNumberField @bind-Value="MaxParallelConnections" Label="Max Parallel Connections" Min="1" Max="20" />
        
        <FluentStack Orientation="Orientation.Horizontal" Gap="10">
            <FluentButton Appearance="Appearance.Accent" @onclick="SaveSettings">Save</FluentButton>
            <FluentButton @onclick="TestConnection">Test Connection</FluentButton>
        </FluentStack>
        
        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <FluentBadge Appearance="Appearance.Neutral">
                @StatusMessage
            </FluentBadge>
        }
    </FluentStack>
</FluentCard>

<FluentCard data-testid="settings-buckets-card">
    <h2>Buckets</h2>
    
    @if (Buckets.Count == 0)
    {
        <p>No buckets configured.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var bucket in Buckets)
                {
                    <tr>
                        <td><FluentTextField @bind-Value="bucket.Name" /></td>
                        <td><FluentTextField @bind-Value="bucket.Description" /></td>
                        <td>
                            <FluentButton @onclick="() => SaveBucket(bucket)">Save</FluentButton>
                            <FluentButton @onclick="() => DeleteBucket(bucket.Id)">Delete</FluentButton>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
        
    <FluentButton @onclick="AddBucket">Add Bucket</FluentButton>
</FluentCard>

<FluentCard>
    <h2>Folder Mappings</h2>
    
    @if (FolderMappings.Count == 0)
    {
        <p>No folder mappings configured.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Folder</th>
                    <th>Assigned Bucket</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mapping in FolderMappings)
                {
                    <tr>
                        <td>@mapping.Name</td>
                        <td>@(GetBucketName(mapping.BucketId))</td>
                        <td>
                            <FluentButton Appearance="Appearance.Accent" Size="Size.Compact" 
                                          @onclick="() => StartEditMapping(mapping.Name)">Edit</FluentButton>
                            <FluentButton Size="Size.Compact" 
                                          @onclick="() => RemoveMapping(mapping.Name)">Remove</FluentButton>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    
    @if (_editMappingName != null)
    {
        <FluentCard>
            <h3>Edit Folder Mapping</h3>
            <FluentStack Orientation="Orientation.Vertical" Gap="10">
                <FluentLabel>Folder</FluentLabel>
                <FluentTextField @bind="_editFolderName" Disabled="true" />
                
                <FluentLabel>Assign to Bucket</FluentLabel>
                <select @bind="_editSelectedBucketId">
                    <option value="">(None)</option>
                    @foreach (var bucket in Buckets)
                    {
                        <option value="@bucket.Id">@bucket.Name</option>
                    }
                </select>
                
                <FluentStack Orientation="Orientation.Horizontal" Gap="10" Justify="Justify.End">
                    <FluentButton Appearance="Appearance.Accent" @onclick="SaveMapping">Save</FluentButton>
                    <FluentButton @onclick="CancelEditMapping">Cancel</FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    }
</FluentCard>

@code {
    [Inject]
    public required IApiClient Api { get; init; }
    
    public string Server { get; set; } = "";
    public int Port { get; set; } = 993;
    public string Username { get; set; } = "";
    public string Password { get; set; } = "";
    public bool UseSsl { get; set; } = true;
    public int MaxParallelConnections { get; set; } = 4;
    
    public string StatusMessage { get; set; } = "";
    
    public List<EditableBucket> Buckets { get; set; } = [];
    public List<FolderMappingDto> FolderMappings { get; set; } = [];
    
    // Folder mapping editing state
    private string? _editMappingName;
    private string _editFolderName = "";
    private string? _editSelectedBucketId;
    
    protected override async Task OnInitializedAsync()
    {
        var settings = await Api.GetSettingsAsync();
        if (settings != null)
        {
            if (settings.ImapSettings != null)
            {
                Server = settings.ImapSettings.Server;
                Port = settings.ImapSettings.Port;
                Username = settings.ImapSettings.Username;
                Password = settings.ImapSettings.Password;
                UseSsl = settings.ImapSettings.UseSsl;
                MaxParallelConnections = settings.ImapSettings.MaxParallelConnections;
            }
            Buckets = settings.Buckets.Select(b => new EditableBucket { Id = b.Id, Name = b.Name, Description = b.Description }).ToList();
            FolderMappings = settings.FolderMappings;
        }
    }
    
    private async Task SaveSettings()
    {
        try
        {
            await Api.SaveSettingsAsync(new AppSettingsDto
            {
                ImapSettings = new ImapSettingsDto
                {
                    Server = Server,
                    Port = Port,
                    Username = Username,
                    Password = Password,
                    UseSsl = UseSsl,
                    MaxParallelConnections = MaxParallelConnections
                },
                Buckets = Buckets.Select(b => new BucketDto(b.Id, b.Name, b.Description)).ToList(),
                FolderMappings = FolderMappings
            });
            StatusMessage = "Settings saved successfully!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private async Task TestConnection()
    {
        try
        {
            await SaveSettings();
            var result = await Api.TestConnectionAsync();
            StatusMessage = result ? "Connection successful!" : "Connection failed!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private void AddBucket()
    {
        Buckets.Add(new EditableBucket { Id = "", Name = "", Description = "" });
    }
    
    private async Task SaveBucket(EditableBucket bucket)
    {
        try
        {
            var dto = new BucketDto(bucket.Id, bucket.Name, bucket.Description);
            if (string.IsNullOrEmpty(bucket.Id))
            {
                var created = await Api.CreateBucketAsync(dto);
                if (created != null)
                {
                    bucket.Id = created.Id;
                }
            }
            else
            {
                await Api.UpdateBucketAsync(dto);
            }
            StatusMessage = "Bucket saved!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private async Task DeleteBucket(string id)
    {
        try
        {
            await Api.DeleteBucketAsync(id);
            Buckets.RemoveAll(b => b.Id == id);
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private string GetBucketName(string? bucketId)
    {
        if (bucketId == null)
        {
            return "(None)";
        }
        var bucket = Buckets.FirstOrDefault(b => b.Id == bucketId);
        return bucket?.Name ?? "(Unknown)";
    }
    
    // Folder mapping editing methods
    private void StartEditMapping(string folderName)
    {
        _editMappingName = folderName;
        _editFolderName = folderName;
        
        // Find current bucket assignment for this folder
        var currentMapping = FolderMappings.FirstOrDefault(m => m.Name == folderName);
        _editSelectedBucketId = currentMapping?.BucketId;
    }
    
    private async Task SaveMapping()
    {
        try
        {
            if (_editMappingName == null) return;
            
            await Api.SetFolderMappingAsync(_editMappingName, _editSelectedBucketId);
            
            // Refresh the folder mappings from the server
            var settings = await Api.GetSettingsAsync();
            if (settings != null)
            {
                FolderMappings = settings.FolderMappings;
            }
            
            CancelEditMapping();
            StatusMessage = "Folder mapping saved successfully!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private void CancelEditMapping()
    {
        _editMappingName = null;
        _editFolderName = "";
        _editSelectedBucketId = null;
    }
    
    private async Task RemoveMapping(string folderName)
    {
        try
        {
            await Api.RemoveFolderMappingAsync(folderName);
            
            // Refresh the folder mappings from the server
            var settings = await Api.GetSettingsAsync();
            if (settings != null)
            {
                FolderMappings = settings.FolderMappings;
            }
            
            StatusMessage = "Folder mapping removed successfully!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
}
