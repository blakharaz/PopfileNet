@page "/settings"
@using PopfileNet.Ui.Services

<FluentCard>
    <h2>IMAP Settings</h2>
    
    <FluentStack Orientation="Orientation.Vertical" Gap="20">
        <FluentTextField @bind-Value="Server" Label="IMAP Server" Placeholder="imap.example.com" />
        <FluentNumberField @bind-Value="Port" Label="Port" Min="1" Max="65535" />
        <FluentTextField @bind-Value="Username" Label="Username" Placeholder="user@example.com" />
        <FluentTextField @bind-Value="Password" Label="Password" Type="Password" />
        <FluentSwitch @bind-Checked="UseSsl" Label="Use SSL" />
        
        <FluentStack Orientation="Orientation.Horizontal" Gap="10">
            <FluentButton Appearance="Appearance.Accent" @onclick="SaveSettings">Save</FluentButton>
            <FluentButton @onclick="TestConnection">Test Connection</FluentButton>
        </FluentStack>
        
        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <FluentBadge>
                @StatusMessage
            </FluentBadge>
        }
    </FluentStack>
</FluentCard>

<FluentCard>
    <h2>Buckets</h2>
    
    <ul>
        @foreach (var bucket in Buckets)
        {
            <li>
                <strong>@bucket.Name</strong> - @bucket.Description
                <FluentButton @onclick="() => DeleteBucket(bucket.Id)">Delete</FluentButton>
            </li>
        }
    </ul>
        
    <FluentButton @onclick="AddBucket">Add Bucket</FluentButton>
</FluentCard>

@code {
    [Inject]
    public ApiClient Api { get; set; } = null!;
    
    public string Server { get; set; } = "";
    public int Port { get; set; } = 993;
    public string Username { get; set; } = "";
    public string Password { get; set; } = "";
    public bool UseSsl { get; set; } = true;
    
    public string StatusMessage { get; set; } = "";
    
    public List<Bucket> Buckets { get; set; } = [];
    
    protected override async Task OnInitializedAsync()
    {
        var settings = await Api.GetSettingsAsync();
        if (settings != null)
        {
            Server = settings.Server;
            Port = settings.Port;
            Username = settings.Username;
            Password = settings.Password;
            UseSsl = settings.UseSsl;
        }
        
        Buckets = await Api.GetBucketsAsync();
        if (Buckets.Count == 0)
        {
            Buckets.Add(new Bucket(Guid.NewGuid(), "Work", "Work emails"));
            Buckets.Add(new Bucket(Guid.NewGuid(), "Personal", "Personal emails"));
        }
    }
    
    private async Task SaveSettings()
    {
        try
        {
            await Api.SaveSettingsAsync(new ImapSettings
            {
                Server = Server,
                Port = Port,
                Username = Username,
                Password = Password,
                UseSsl = UseSsl
            });
            StatusMessage = "Settings saved successfully!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private async Task TestConnection()
    {
        try
        {
            await SaveSettings();
            var result = await Api.TestConnectionAsync();
            StatusMessage = result ? "Connection successful!" : "Connection failed!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private void AddBucket()
    {
        Buckets.Add(new Bucket(Guid.NewGuid(), "", ""));
    }
    
    private async Task DeleteBucket(Guid id)
    {
        await Api.DeleteBucketAsync(id);
        Buckets.RemoveAll(b => b.Id == id);
    }
}
