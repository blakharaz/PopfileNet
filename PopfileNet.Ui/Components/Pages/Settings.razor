@page "/settings"
@using PopfileNet.Ui.Services

<FluentCard>
    <h2>IMAP Settings</h2>
    
    <FluentStack Orientation="Orientation.Vertical" Gap="20">
        <FluentTextField @bind-Value="Server" Label="IMAP Server" Placeholder="imap.example.com" />
        <FluentNumberField @bind-Value="Port" Label="Port" Min="1" Max="65535" />
        <FluentTextField @bind-Value="Username" Label="Username" Placeholder="user@example.com" />
        <FluentTextField @bind-Value="Password" Label="Password" Type="Password" />
        <FluentSwitch @bind-Checked="UseSsl" Label="Use SSL" />
        
        <FluentStack Orientation="Orientation.Horizontal" Gap="10">
            <FluentButton Appearance="Appearance.Accent" @onclick="SaveSettings">Save</FluentButton>
            <FluentButton @onclick="TestConnection">Test Connection</FluentButton>
        </FluentStack>
        
        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <FluentBadge Appearance="Appearance.Neutral">
                @StatusMessage
            </FluentBadge>
        }
    </FluentStack>
</FluentCard>

<FluentCard>
    <h2>Buckets</h2>
    
    @if (Buckets.Count == 0)
    {
        <p>No buckets configured.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var bucket in Buckets)
                {
                    <tr>
                        <td><FluentTextField @bind-Value="bucket.Name" /></td>
                        <td><FluentTextField @bind-Value="bucket.Description" /></td>
                        <td>
                            <FluentButton @onclick="() => SaveBucket(bucket)">Save</FluentButton>
                            <FluentButton @onclick="() => DeleteBucket(bucket.Id)">Delete</FluentButton>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
        
    <FluentButton @onclick="AddBucket">Add Bucket</FluentButton>
</FluentCard>

<FluentCard>
    <h2>Folder Mappings</h2>
    
    @if (FolderMappings.Count == 0)
    {
        <p>No folder mappings configured.</p>
    }
    else
    {
        <ul>
            @foreach (var mapping in FolderMappings)
            {
                <li>
                    <strong>@mapping.Name</strong> → @(GetBucketName(mapping.BucketId))
                </li>
            }
        </ul>
    }
</FluentCard>

@code {
    [Inject]
    public ApiClient Api { get; set; } = null!;
    
    public string Server { get; set; } = "";
    public int Port { get; set; } = 993;
    public string Username { get; set; } = "";
    public string Password { get; set; } = "";
    public bool UseSsl { get; set; } = true;
    
    public string StatusMessage { get; set; } = "";
    
    public List<BucketDto> Buckets { get; set; } = [];
    public List<FolderMappingDto> FolderMappings { get; set; } = [];
    
    protected override async Task OnInitializedAsync()
    {
        var settings = await Api.GetSettingsAsync();
        if (settings != null)
        {
            if (settings.ImapSettings != null)
            {
                Server = settings.ImapSettings.Server;
                Port = settings.ImapSettings.Port;
                Username = settings.ImapSettings.Username;
                Password = settings.ImapSettings.Password;
                UseSsl = settings.ImapSettings.UseSsl;
            }
            Buckets = settings.Buckets;
            FolderMappings = settings.FolderMappings;
        }
        
        if (Buckets.Count == 0)
        {
            Buckets =
            [
                new BucketDto(Guid.NewGuid(), "Work", "Work emails"),
                new BucketDto(Guid.NewGuid(), "Personal", "Personal emails")
            ];
        }
    }
    
    private async Task SaveSettings()
    {
        try
        {
            await Api.SaveSettingsAsync(new AppSettingsDto
            {
                ImapSettings = new ImapSettingsDto
                {
                    Server = Server,
                    Port = Port,
                    Username = Username,
                    Password = Password,
                    UseSsl = UseSsl
                },
                Buckets = Buckets,
                FolderMappings = FolderMappings
            });
            StatusMessage = "Settings saved successfully!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private async Task TestConnection()
    {
        try
        {
            await SaveSettings();
            var result = await Api.TestConnectionAsync();
            StatusMessage = result ? "Connection successful!" : "Connection failed!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private void AddBucket()
    {
        Buckets.Add(new BucketDto(Guid.NewGuid(), "", ""));
    }
    
    private async Task SaveBucket(BucketDto bucket)
    {
        try
        {
            if (bucket.Id == Guid.Empty)
            {
                await Api.CreateBucketAsync(bucket);
            }
            else
            {
                await Api.UpdateBucketAsync(bucket);
            }
            StatusMessage = "Bucket saved!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private async Task DeleteBucket(Guid id)
    {
        try
        {
            await Api.DeleteBucketAsync(id);
            Buckets.RemoveAll(b => b.Id == id);
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
    
    private string GetBucketName(Guid? bucketId)
    {
        if (bucketId == null) return "(None)";
        var bucket = Buckets.FirstOrDefault(b => b.Id == bucketId);
        return bucket?.Name ?? "(Unknown)";
    }
}
