@page "/classify"
@using PopfileNet.Ui.Services

<FluentCard>
    <h2>Email Classifier</h2>
    
    <FluentStack Orientation="Orientation.Vertical" Gap="20">
        <FluentCard>
            <h3>Training</h3>
            <FluentStack Orientation="Orientation.Vertical" Gap="10">
                <p>Status: <strong>@(Status?.IsTrained == true ? "Trained" : "Not Trained")</strong></p>
                <p>Training Data: @(Status?.TrainingDataCount ?? 0) emails</p>
                <FluentButton Appearance="Appearance.Accent" @onclick="Train" Disabled="@IsTraining">
                    @(IsTraining ? "Training..." : "Train Model")
                </FluentButton>
            </FluentStack>
        </FluentCard>
        
        <FluentCard>
            <h3>Prediction</h3>
            <FluentStack Orientation="Orientation.Vertical" Gap="10">
                <p>Select an email to classify:</p>
                
                <table>
                    <thead>
                        <tr>
                            <th>Select</th>
                            <th>Subject</th>
                            <th>From</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var email in (Emails?.Items ?? []))
                        {
                            <tr>
                                <td><input type="radio" name="emailSelect" checked="@(SelectedEmailId == email.Id)" @onclick="() => SelectedEmailId = email.Id" /></td>
                                <td>@email.Subject</td>
                                <td>@email.FromAddress</td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                <FluentButton 
                    Appearance="Appearance.Accent" 
                    @onclick="Predict" 
                    Disabled="@(!Status?.IsTrained == true || string.IsNullOrEmpty(SelectedEmailId))">
                    Classify Selected Email
                </FluentButton>
                
                @if (Prediction != null)
                {
                    <FluentCard>
                        <h4>Result</h4>
                        <p>Predicted Bucket: <strong>@Prediction.PredictedBucket</strong></p>
                        <p>Confidence: @((Prediction.Confidence * 100).ToString("F1"))%</p>
                        
                        @if (Prediction.AllProbabilities.Count > 0)
                        {
                            <h5>All Probabilities:</h5>
                            <ul>
                                @foreach (var prob in Prediction.AllProbabilities.OrderByDescending(p => p.Value))
                                {
                                    <li>@prob.Key: @((prob.Value * 100).ToString("F1"))%</li>
                                }
                            </ul>
                        }
                    </FluentCard>
                }
            </FluentStack>
        </FluentCard>
        
        <FluentCard>
            <h3>Categories</h3>
            @if (Categories?.Items.Count > 0)
            {
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Categories.Items)
                        {
                            <tr>
                                <td>@cat.Name</td>
                                <td>@cat.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>No categories configured.</p>
            }
        </FluentCard>
        
        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <FluentBadge Appearance="Appearance.Neutral">
                @StatusMessage
            </FluentBadge>
        }
    </FluentStack>
</FluentCard>

@code {
    [Inject]
    public IApiClient Api { get; set; } = null!;
    
    public ClassifierStatus? Status { get; set; }
    public PagedResponse<EmailDto>? Emails { get; set; }
    public PagedResponse<BucketDto>? Categories { get; set; }
    public string? SelectedEmailId { get; set; }
    public PredictionResult? Prediction { get; set; }
    public string StatusMessage { get; set; } = "";
    public bool IsTraining { get; set; }
    
    protected override async Task OnInitializedAsync()
    {
        Status = await Api.GetClassifierStatusAsync();
        Categories = await Api.GetCategoriesAsync(1, 100);
        Emails = await Api.GetMailsAsync(1, 50);
        StatusMessage = "";
    }
    
    private async Task Train()
    {
        try
        {
            IsTraining = true;
            await Api.TrainClassifierAsync();
            Status = await Api.GetClassifierStatusAsync();
            StatusMessage = "Model trained successfully!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsTraining = false;
        }
    }
    
    private async Task Predict()
    {
        if (string.IsNullOrEmpty(SelectedEmailId)) return;
        
        try
        {
            Prediction = await Api.PredictAsync(SelectedEmailId);
            StatusMessage = Prediction != null ? "Classification complete!" : "Classification failed.";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
}
